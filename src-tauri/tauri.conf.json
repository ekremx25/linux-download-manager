{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linux Download Manager",
  "version": "0.1.0",
  "identifier": "com.eko.linuxdownloadmanager",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Linux Download Manager",
        "width": 1200,
        "height": 820,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/icon.png",
      "icons/256x256.png",
      "icons/512x512.png"
    ],
    "resources": [
      "icons/icon.png",
      "../browser/chromium/*"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
